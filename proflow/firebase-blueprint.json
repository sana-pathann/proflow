{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with global role information.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "MEMBER"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "displayName", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "A project containing tasks and members.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "status": { "type": "string", "enum": ["ACTIVE", "COMPLETED", "ARCHIVED"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "priority", "status", "ownerId"]
    },
    "ProjectMember": {
      "title": "Project Member",
      "description": "A user assigned to a project with a specific role.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "MEMBER"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "A task within a project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["TODO", "IN_PROGRESS", "COMPLETED"] },
        "assigneeId": { "type": "string" },
        "projectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "priority", "status", "projectId"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Log of actions performed in a project.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      },
      "required": ["userId", "action", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global user profiles."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Main project collection."
    },
    "/projects/{projectId}/members/{memberId}": {
      "schema": "ProjectMember",
      "description": "Users assigned to the project."
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks within a project."
    },
    "/projects/{projectId}/activity/{activityId}": {
      "schema": "ActivityLog",
      "description": "Recent activity in a project."
    }
  }
}
